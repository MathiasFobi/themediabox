{
  "name": "themediabox-guestbook",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone video guest book app for TheMediaBox — Cloudflare Workers + Firestore + Firebase Auth + Cloudflare Stream",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail",
    "secret:cf-stream": "wrangler secret put CLOUDFLARE_STREAM_TOKEN",
    "secret:fb-private": "wrangler secret put FIREBASE_PRIVATE_KEY"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.90.0"
  },
  "dependencies": {
    "dev": "^0.1.5",
    "hono": "^4.6.0",
    "jose": "^6.2.3"
  }
}
